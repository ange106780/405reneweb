$(function(){$('#account-form').AccountForm();$('.generic-help').help({width:500})});var Account={};$.fn.AccountForm=function(){return this.each(function(){$(this).data('accountForm',new Account.Form(this))})};Account.Form=function(element){this.$element=$(element);this._init();this._initAccountTabs();this._initAccountClosureCheckbox();this._initTfa()};Account.Form.prototype={_init:function(){$('.preview-password').prevue();$('.ui-cp-validate').validatePassword();var self=this;$('#account-closure-form, #account-password-form, #account-info-form',self.$element).submit(function(e){e.preventDefault();var $self=$(this),action=$self.attr('action'),fields=$self.serialize(),close=$self.data('close');$.post(action,fields,function(json){$.parseResponse(json,{onSuccess:function(rs){$.notify.showSuccess(rs.msg);if(close==true)setTimeout(function(){window.location='account'},2e3);if(rs.redirect)window.location=rs.redirect},onError:function(rs){$.notify.showError(rs.msg)}})})});$('.generate-password',self.$element).on('click',function(e){e.preventDefault();$('input[name=passwordNew]',self.$element).val($.passGen());$('input[name=passwordNew]',self.$element).trigger('input');if($(".prevue-icon-eye",$(this).parent())[0])$('.prevue-btn',$(this).parent()).trigger('click')})},_initAccountTabs:function(){var self=this;if('onhashchange'in window)$(window).on('hashchange',function(e){$('a[href="account/'+window.location.hash+'"]').trigger('click')});var borderTop=self.$element.tabs({beforeActivate:function(e){window.location.hash=e.currentTarget.hash}}).removeClass('ui-widget-content').children('div.ui-tabs-panel').addClass('ui-corner-all').parent().children('ul.ui-tabs-nav').removeClass('ui-widget-header').children('li').removeClass('ui-corner-top').addClass('ui-corner-left').eq(0).css('borderTopColor');$('.ui-tabs-nav li',self.$element).attr('style','border-bottom-color: '+borderTop+' !important')},_initAccountClosureCheckbox:function(){$('#closure-all',this.$element).click(function(){if(this.checked){$.each($('input.closure'),function(){$(this).prop({disabled:true,checked:false})})}else $.each($('input.closure'),function(){$(this).prop('disabled',false)})})},_initTfa:function(){var $tfaDialog=$('#2fa-dialog');$tfaDialog.dialog({autoOpen:false,modal:true,width:600});this.$tfaDialog=$tfaDialog;this._processTfaElement($('#account-2fa'))},_updateTfaDialog:function(rs){var main=this,$tfaDialog=this.$tfaDialog;if(rs.errno){$.notify.showError(rs.msg);return};if(rs.changed)$.get('account/get2FADetails',{},function(json){$.parseResponse(json,{onSuccess:function(rs){if(rs.errno)$.notify.showError(rs.msg);if(rs.contents){$('#account-2fa-contents').html(rs.contents);main._processTfaElement($('#account-2fa'))}},onError:function(rs){$.notify.showError(rs.msg)}})});if(rs.msg)$.notify.showSuccess(rs.msg);if(!rs.contents){$tfaDialog.dialog('close');return};$('.2fa-dialog-contents',$tfaDialog).html(rs.contents);$tfaDialog.dialog({title:$('.2fa-dialog-inner',$tfaDialog).data('dialog-title'),width:Math.min($(window).width()*0.9,1200),position:{my:"center top",at:"center top+80px",of:window}});$tfaDialog.dialog('open');$('.ui-cp-cancel',this.$tfaDialog).on('click',function(ev){ev.preventDefault();$tfaDialog.dialog('close')});main._processTfaElement($tfaDialog)},_processTfaElement:function($element){var main=this;$('.ui-cp-button',$element).button();var $openable=$('.2fa-open-in-dialog, .2fa-keep-in-dialog, .2fa-close-dialog',$element),$links=$openable.filter('a'),$forms=$openable.filter('form'),$tfaDialog=this.$tfaDialog,onResponse=function(json){$.parseResponse(json,{onSuccess:function(rs){main._updateTfaDialog(rs)},onError:function(rs){$.notify.showError(rs.msg)}})};$links.on('click',function(ev){var $self=$(this);ev.preventDefault();$.get($self.attr('href'),{},onResponse);$});$forms.on('submit',function(ev){var $self=$(this);ev.preventDefault();$.post($self.attr('action'),$self.serialize(),onResponse);$});$forms.each(function(){var $form=$(this);$('.ui-cp-submit',$form).on('click',function(ev){ev.preventDefault();$form.trigger('submit')})});$('.tfa-show-key-details',$element).on('click',function(ev){ev.preventDefault();$('.tfa-secret-details-autohide').show();$('.tfa-show-key-details').hide()})}}