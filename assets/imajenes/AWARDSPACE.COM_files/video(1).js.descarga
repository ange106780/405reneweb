$.fn.videoBox=function(options){var opts=$.extend(true,{sources:[],tracks:[],cssClass:'',videojs:{controls:true,autoplay:false,preload:'none',loop:false,width:800,height:600}},options);this.each(function(){$(this).data('video.box',new Video.Box(this,opts))});return this};var Video={};Video.Box=function(element,opts){var self=this;self.opts=opts;self.$element=$(element);self.$overlay=null;self.$video=null;self.player=null;self.init()};Video.Box.prototype={init:function(){var self=this,videoId='video-'+Math.random().toString(36).substr(2,8),srcHtml='',trackHtml='';$.each(self.opts.sources,function(i,v){srcHtml+='<source type="'+v.type+'" src="'+v.src+'"></source>'});$.each(self.opts.tracks,function(i,v){trackHtml+='<track kind="'+v.kind+'" src="'+v.src+'" srclang="'+v.srclang+'" label="'+v.label+'" '+(v.isDefault?'default':'')+'>'});self.$overlay=$('<div />',{'class':'ui-widget-overlay',css:{position:'fixed',display:'none','z-index':999}}).click(function(){self.hide()}).appendTo('body');self.$video=$('<div />',{'class':'ui-widget-content ui-corner-all',css:{position:'absolute',left:'50%',top:'50%',display:'none','z-index':999,'margin-left':-(self.opts.videojs.width/2)+'px','margin-top':-(self.opts.videojs.height/2)+'px','border-width':'3px'},html:'<span class="video-close"></span><video id="'+videoId+'" class="video-js vjs-default-skin '+self.opts.cssClass+'" width="'+self.opts.videojs.width+'" height="'+self.opts.videojs.height+'">'+srcHtml+trackHtml+'</video>'}).appendTo('body');$('.video-close',self.$video).css({position:'absolute',right:'10px',top:'-21px',padding:'0 10px',height:'16px',cursor:'pointer','border-width':'2px'}).click(function(){self.hide()}).append('<span class="ui-icon ui-icon-closethick" />').addClass('ui-widget-content ui-corner-tl ui-corner-tr');self.player=_V_(videoId,self.opts.videojs);$(window).on('resize.video',function(){var width=$(this).width()-50,height=$(this).height()-50;if(width<self.opts.videojs.width){self.player.width(width);self.$video.css('margin-left',-(width/2)+'px')}else if(self.player.width()!=self.opts.videojs.width){self.player.width(self.opts.videojs.width);self.$video.css('margin-left',-(self.opts.videojs.width/2)+'px')};if(height<self.opts.videojs.height){self.player.height(height);self.$video.css('margin-top',-(height/2)+'px')}else if(self.player.height()!=self.opts.videojs.height){self.player.height(self.opts.videojs.height);self.$video.css('margin-top',-(self.opts.videojs.height/2)+'px')}}).trigger('resize.video');$(document).keyup(function(e){if(e.keyCode==27)self.hide()})},show:function(){this.$overlay.fadeIn(200);this.$video.fadeIn(200)},hide:function(){this.$video.fadeOut(200);this.$overlay.fadeOut(200);this.player.pause()}}