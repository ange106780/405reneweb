if(typeof Object.create!=='function')Object.create=function(o){function F(){};F.prototype=o;return new F()};$.plugin=function(name,object,construct){$.fn[name]=function(options){var args=Array.prototype.slice.call(arguments,1);return this.each(function(){var instance=$.data(this,name);if(instance){instance[options].apply(instance,args)}else{construct=(construct?construct:'init');instance=$.data(this,name,Object.create(object)[construct](this,options))}})}}