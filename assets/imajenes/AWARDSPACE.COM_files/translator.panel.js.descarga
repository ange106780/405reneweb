$(function(){$('#translator-panel').translatorPanel()});$.fn.translatorPanel=function(){return this.each(function(){$(this).data('translator.panel',new Translator.Panel(this))})};var Translator=Translator||{};Translator.Panel=function(element){this.$element=$(element);this._init()};Translator.Panel.prototype={_init:function(){var self=this;$('a.compile',self.$element).click(function(){if(confirm('Are you sure?'))self.compileLanguage()})},_openPanel:function(trigger){$(trigger).addClass('active ui-custom-border-light');$(trigger).next('.sub-panel').fadeIn(300)},_closePanel:function(trigger){$(trigger).removeClass('active ui-custom-border-light');$(trigger).next('.sub-panel').fadeOut(300)},compileLanguage:function(){$.get('translator/compile',function(json){$.parseResponse(json,{onSuccess:function(rs){$.notify.showSuccess(rs.msg)},onError:function(rs){$.notify.showError(rs.msg)}})})}}