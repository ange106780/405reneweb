$(function(){$('.ui-cp-disable-notification').disableNotification()});$.fn.disableNotification=function(){this.each(function(){$(this).data('disable.notification',new DisableNotification(this))})};var DisableNotification=function(element){this.$element=$(element);this._init()};DisableNotification.prototype={_init:function(){var self=this;$(self.$element).on('click',function(){var params={'notification-id':$(this).data('notification-id'),platform:$(this).data('platform')};$.post('notifications/disableNotification',params,function(json){$.parseResponse(json,{onSuccess:function(rs){$.notify.showSuccess(rs.msg);$(self.$element).closest('.ui-cp-message').fadeOut(500)},onError:function(rs){$.notify.showError(rs.msg)}})})})}}