var PanelWidget=function(element,options){var self=this;self.$element=$(element);self.opts=options;var $controls=$('> div > .ui-cp-widget-controls',self.$element),$options=$('> .ui-cp-widget-options',self.$element),$title=$('.ui-cp-widget-title',self.$element),title,titleTimer=null;$controls.children('span').hover(function(){$(this).removeClass('ui-cp-state-dummy').addClass('ui-state-hover')},function(){$(this).addClass('ui-cp-state-dummy').removeClass('ui-state-hover')});$controls.children('span.ui-cp-widget-controls-toggle').click(function(){if(!self.$element.data('collapsed')){self.$element.data('collapsed',true);self.opts.onUpdate();$('.ui-icon',this).switchClass('ui-icon-arrowthickstop-1-n','ui-icon-arrowthickstop-1-s',0);var $content=$('> .ui-cp-widget-content-inner',self.$element);$content.slideUp(800)}else{self.$element.data('collapsed',false);self.opts.onUpdate();$('.ui-icon',this).switchClass('ui-icon-arrowthickstop-1-s','ui-icon-arrowthickstop-1-n',0);$('> .ui-cp-widget-content-inner',self.$element).slideDown(1e3)}});$controls.children('span.ui-cp-widget-controls-remove').click(function(){$('#dialog-remove-widget').dialog({modal:true,open:function(){$('.ui-dialog-buttonpane button',$(this).parent()).blur().last().focus()},buttons:{Confirm:function(e,ui){$(this).dialog('close');self.$element.fadeOut(400,function(){self.$element.remove();self.opts.onUpdate()})},Cancel:function(){$(this).dialog('close')}}})});$controls.children('span.ui-cp-widget-controls-edit').on('click',function(){if($(this).closest('li').find('form').is(':hidden')){$('input.widget-title',self.$element).val($('span.ui-cp-widget-title',self.$element).text());$options.slideDown(400);$(this).removeClass('ui-cp-state-dummy').addClass('ui-state-active')}else{$options.slideUp(400);$(this).addClass('ui-cp-state-dummy').removeClass('ui-state-active')}});$options.children('span.ui-cp-widget-options-close').hover(function(){$(this).removeClass('ui-cp-state-dummy').addClass('ui-state-hover')},function(){$(this).addClass('ui-cp-state-dummy').removeClass('ui-state-hover')}).click(function(){$controls.children('span.ui-cp-widget-controls-edit').trigger('click')});$options.submit(function(e){e.preventDefault();$controls.children('span.ui-cp-widget-controls-edit').trigger('click')}).find('input.widget-title').on('input keyup cut paste',function(){title=$(this).val();titleTimer=self.$element.data('_titleTimer');if(typeof titleTimer!='undefined')clearTimeout(titleTimer);$title.text(title);self.$element.data('_titleTimer',setTimeout(function(){self.$element.data('title',title);self.opts.onUpdate()},2e3))})};PanelWidget.prototype={refresh:function(){if(this.$element.data('type')=='tools')if($('li.ui-cp-widget-tool',this.$element).length>0){$('.ui-cp-widget-empty',this.$element).fadeOut(300)}else $('.ui-cp-widget-empty',this.$element).fadeIn(300)},getSettings:function(){var data=this.$element.data(),settings={deletable:data.deletable,editable:data.editable,movable:data.movable,collapsible:data.collapsible,collapsed:data.collapsed,type:data.type};if(typeof data.title!='undefined')settings.title=data.title;return settings}};$.fn.panelWidget=function(options){var opts=$.extend({onUpdate:function(){}},options);this.each(function(){$(this).data('panelWidget',new PanelWidget(this,opts))});return this};var PanelWidgetTool=function(element,options){var self=this;self.$element=$(element);self.opts=options;$('a',self.$element).hover(function(){$(this).removeClass('ui-cp-state-dummy').addClass('ui-state-hover')},function(){$(this).addClass('ui-cp-state-dummy').removeClass('ui-state-hover')}).children('span.ui-cp-widget-tool-remove').click(function(e){e.preventDefault();$('#dialog-remove-tool').dialog({modal:true,open:function(){$('.ui-dialog-buttonpane button',$(this).parent()).blur().last().focus()},buttons:{Confirm:function(e,ui){$(this).dialog('close');self.$element.fadeOut(400,function(){var panelWidget=self.$element.parents('.widget').data('panelWidget');self.$element.remove();panelWidget.refresh();self.opts.onUpdate()})},Cancel:function(){$(this).dialog('close')}}})})};$.fn.panelWidgetTool=function(options){var opts=$.extend({onUpdate:function(){}},options);this.each(function(){$(this).data('panelWidgetTool',new PanelWidgetTool(this,opts))});return this}