$.fn.dropdown=function(options){if(typeof options=='string')return this.data('dropdown')[options]();this.each(function(){var $element=$(this),$dropdown=$element.data('dropdown');if(typeof $dropdown=='object'){$dropdown.$element=$element;$dropdown._reInit()}else $(this).data('dropdown',new Dropdown(this))});return this};var Dropdown=function(element){this.$element=$(element);this._init()};Dropdown.prototype._init=function(){var self=this;self.$element.each(function(){var $control=$(this),$select=$('select',this),$selectedOption=$('select option',this).filter(':selected'),attr=$selectedOption.attr('selected');if(typeof attr==='undefined'||attr===false)var text=$select.attr('placeholder');if(!text){$control.data('placeholderUsed',false);text=$selectedOption.text()}else{$control.data('placeholderUsed',true);$select.prepend('<option value="">'+text+'</option>').val('')};var $span=$('<span />',{text:text});$control.prepend($span)}).on('change keypress dropdown.updated',function(){$('span',this).text($('select option',this).filter(':selected').text());self._removePlaceholderElement($(this))})};Dropdown.prototype._removePlaceholderElement=function($control){if($control.data('placeholderUsed')){$control.data('placeholderUsed',false);$('select option',$control).eq(0).remove()}};Dropdown.prototype._reInit=function(){if(!this.$element.data('placeholderUsed')){var $select=$('select',this.$element),$selectedOption=$('select option',this.$element).filter(':selected'),attr=$selectedOption.attr('selected');if(typeof attr==='undefined'||attr===false)var text=$select.attr('placeholder');if(text!=''){this.$element.data('placeholderUsed',true);$select.prepend('<option value="">'+text+'</option>').val('');$('span',this.$element).text(text)}}}