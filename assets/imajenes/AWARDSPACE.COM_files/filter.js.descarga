var Filter={};$.fn.filterPlugin=function(options){if(typeof options=='string')return this.data('filterPlugin')[options]();var opts=$.extend({},options);return this.each(function(){$(this).data('filterPlugin',new Filter.Plugin(this,opts))})};Filter.Plugin=function(element,opts){this.$element=$(element);this.$opts=opts;this._init()};Filter.Plugin.prototype={_init:function(){var self=this;if(self.$element.next('table').length>0){var tableBody=self.$element.next('table').find('tbody')}else var tableBody=self.$element.parent().next('table').find('tbody');self.$element.keyup(function(){var toFilter=tableBody.children('tr');toFilter.hide();var text=this.value;toFilter=toFilter.filter(function(index){return($(this).find('td .to-filter:contains("'+text+'")').length>0||text.length==0)});toFilter.show();$.each(toFilter,function(index,value){$(this).find('.ui-cp-grid-toggle-controls-open').closest('tr').next('tr').show();$(this).find('.ui-cp-grid-toggle-controls-closed').closest('tr').next('tr').hide();$(this).find('.open').closest('tr').next('tr').show();$(this).find('.closed').closest('tr').next('tr').hide()})})}}