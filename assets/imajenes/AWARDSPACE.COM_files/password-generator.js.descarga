(function($){$.passGen=function(options,required){options=$.extend({},$.passGen.options,options);required=$.extend({},$.passGen.required,required);var charsets,charset='',password='',charsetR={},index;charsets={numeric:'0123456789',lowercase:'abcdefghijklmnopqrstuvwxyz',uppercase:'ABCDEFGHIJKLMNOPQRSTUVWXYZ',special:'~.:,;!@#%^*()_=/-+[]{}?'};$.each(charsets,function(key,value){if(required[key])charsetR[key]=value;if(options[key])charset+=value});for(var i=0;i<options.length;i++){index=Math.floor(Math.random()*(charset.length));if(i==Math.round(options.length)/2&&!$.isEmptyObject(charsetR)){var flag=false;$.each(charsetR,function(key,value){index=Math.floor(Math.random()*(charsetR[key].length));if(flag)i++;flag=true;password+=charsetR[key][index]})}else password+=charset[index]};return password};$.passGen.options={length:16,numeric:true,lowercase:true,uppercase:true,special:true};$.passGen.required={numeric:true,special:false}}(jQuery))