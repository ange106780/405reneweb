$(function(){new Dashboard()});var Dashboard=function(){this.$sidebar=$('#left-sidebar');this.$dashboard=$('#dashboard');this.$boards=$('#dashboard, #left-sidebar');this._init()};Dashboard.prototype={_init:function(){var self=this,$widgets,$tools=null;self.sortableFn={start:function(ui){ui.item.data('_itemIndex',ui.item.index()).fadeTo(400,0.6)},stop:function(ui){self.update();$('li.section[data-self="custom"] li.ui-cp-widget[data-type="tools"]',self.$boards).each(function(){$(this).data('panelWidget').refresh()});ui.item.fadeTo(400,(ui.item.hasClass('ui-cp-widget-tool-inactive')?0.4:1))},receive:function(ui,type){var itemSection=ui.item.parents('li.section').data('self'),senderSection=ui.sender.parents('li.section').data('self');if(senderSection=='custom'&&(ui.item.is('li[data-type="system-status"]')||ui.item.is('li[data-type="hosting-statistics"]')||ui.item.is('li[data-type="hosting-features"]'))){ui.sender.sortable('cancel');return};if(itemSection!='custom'||senderSection=='custom')return;var $item=ui.item.clone(),$sibling=$('li.'+type,ui.sender).eq(ui.item.data('_itemIndex'));ui.item.data('editable',true);if($sibling.length>0){$sibling.before($item)}else ui.sender.append($item);switch(type){case'widget':var newId=Math.random().toString(36).substr(2,8);ui.item.data('self','widget-'+newId).data('title',ui.item.find('span.ui-cp-widget-title').text());ui.item.find('span.ui-cp-widget-controls-remove, span.ui-cp-widget-controls-edit').show();ui.item.find('input.widget-title').attr('id','widget-title-'+newId).prev().attr('for','widget-title-'+newId);$tools=$('ul.ui-cp-widget-tools',$item);self.makeWidget($item).fadeTo(400,1);self.makeTool($tools.children('li.widget-tool'));ui.sender.sortable('refresh');self.makeToolsSortable($tools);break;case'widget-tool':self.makeTool($item).fadeTo(400,($item.hasClass('ui-cp-widget-tool-inactive')?0.4:1));break}}};$('.section',this.$boards).not('.sidebar').panelWidget({onUpdate:function(){self.update()}});$('.section',this.$boards).e