ms:'> li[data-movable="true"]',placeholder:'widget ui-cp-widget ui-cp-widget-placeholder ui-corner-all',connectWith:[$widgets,'li.section[data-self="custom"] ul.ui-cp-widgets'],start:function(e,ui){self.sortableFn.start(ui)},stop:function(e,ui){self.sortableFn.stop(ui)},receive:function(e,ui){self.sortableFn.receive(ui,'widget')},over:function(e,ui){if(ui.item.is('li[data-self="system-status"]'))ui.sender.sortable('cancel')}})},makeToolsSortable:function($tools){var self=this;$tools.sortable({helper:'clone',revert:true,distance:5,placeholder:'ui-cp-widget-tool widget-tool-placeholder ui-corner-all',connectWith:[$tools,'li.section[data-self="custom"] ul.ui-cp-widget-tools'],start:function(e,ui){self.sortableFn.start(ui);ui.placeholder.append($('<a />').height(ui.helper.find('a').height()).addClass('ui-cp-widget-placeholder ui-corner-all'))},stop:function(e,ui){self.sortableFn.stop(ui)},receive:function(e,ui){self.sortableFn.receive(ui,'widget-tool')}})},getDashboardSettings:function(){var $section=$('.section',this.$dashboard),pos=null,psection,pwidgets,pwidgetsPos,pwidget,ptools,ptool=null,sections={},$widgets=null;$section.each(function(){psection=sections[$(this).data('self')]=$(this).data('panelWidget').getSettings();$widgets=$('ul.ui-cp-widgets',this);if($widgets.length>0){pwidgets=psection.widgets={};$widgets.each(function(){pos=$(this).data('pos');if(typeof pwidgets[pos]!='object')pwidgetsPos=pwidgets[pos]={};$('li.ui-cp-widget',this).each(function(){pwidget=pwidgetsPos[$(this).data('self')]=$(this).data('panelWidget').getSettings();switch(pwidget.type){case'tools':ptools=pwidget.tools={};$('ul.ui-cp-widget-tools',this).each(function(){ptool=ptools[$(this).data('pos')]=[];$('li.ui-cp-widget-tool',this).each(function(){ptool.push($(this).data('self'))})});case'first-steps':break}})})}});return $.toJSON(sections)},getSidebarSettings:function(){var widgets={},pwidget,ptools,ptool=null;$('.section.sidebar ul.ui-cp-widgets li.ui-cp-widget',this.$sidebar).each(function(){pwidget=widgets[$(this).data('self')]=$(this).data('panelWidget').getSettings();switch(pwidget.type){case'tools':ptools=pwidget.tools={};$('ul.ui-cp-widget-tools',this).each(function(){ptool=ptools[$(this).data('pos')]=[];$('li.ui-cp-widget-tool',this).each(function(){ptool.push($(this).data('self'))})});case'first-steps':break}});return $.toJSON(widgets)},update:function(){if(this.$sidebar.length>0)$.post('settings/sidebar',this.getSidebarSettings());if(this.$dashboard.length>0)$.post('settings/dashboard',this.getDashboardSettings())}}