$.fn.input=function(options){if(typeof options=='string')return this.data('input')[options]();this.each(function(){$(this).data('input',new Input(this))});return this};var Input=function(element){this.$element=$(element);this._init()};Input.prototype={_init:function(){var self=this,width=0,$span=null;self.$element.each(function(){var data=$(this).data();if(typeof data.prefix!='undefined'){$span=$('<span />',{text:data.prefix,'class':'ui-cp-input-prefix'});$(this).before($span);if((width=$span.width())==0){var $_helper=$span.clone().css({visibility:'hidden','font-size':'1.1em'}).appendTo('body');width=$_helper.width();$_helper.remove()};$(this).css('padding-left',(width+2)+'px').css('width',function(i,v){return(parseInt(v)-width+2)+'px'})}})}}