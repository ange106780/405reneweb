$.fn.help=function(options){if(typeof options=='string')return this.data('help')[options]();var opts=$.extend({url:null,timeToAppear:500,timeToDisappear:500,offsetTop:0,offsetLeft:0,width:270,height:'auto',onBeforeLoad:function(){},onAfterLoad:function(){}},options);this.each(function(){$(this).data('help',new Help(this,opts))});return this};var Help=function(element,opts){var self=this;self.opts=opts;self.$element=$(element);self.$panel=null;self.$element.mouseenter(function(){var timer=setTimeout(function(){$('.ui-cp-help-panel:visible').trigger('mouseleave');if(self.$panel!==null){var timer=self.$panel.data('timer');if(typeof timer!='undefined')clearTimeout(timer);self.adjust();self.$panel.show();return};var dataUrl=self.$element.data('help-url'),staticContent=self.$element.data('content'),showStaticText=(typeof staticContent!='undefined');if(typeof dataUrl!='undefined'){url=dataUrl}else if(showStaticText);else if(self.opts.url!=null){url=self.opts.url}else return;self.$panel=self.createPanel();self.adjust();var showContentFunction=function(content){$('.ui-cp-help-content',self.$panel).html(content);self.opts.onAfterLoad.call(element,self.$panel)};if(showStaticText){showContentFunction(staticContent)}else{self.opts.onBeforeLoad.call(element,self.$panel);$.get(url,showContentFunction)}},self.opts.timeToAppear);self.$element.data('timer',timer)}).mouseleave(function(){if(self.$panel!==null&&self.$panel.is(':visible')){self.$panel.data('timer',setTimeout(function(){self.$panel.hide()},self.opts.timeToDisappear))}else clearTimeout(self.$element.data('timer'))})};Help.prototype={createPanel:function(){var self=this;return $('<div class="ui-cp-help-panel ui-widget ui-widget-content ui-corner-all"><div class="ui-cp-help-content"><img src="media/css/images/ajax-loader-16-16.gif"></div><div class="ui-cp-help-pointer-up ui-widget-content"><div class="ui-cp-help-pointer-up-inner ui-widget-content"></div></div></div>').css({width:self.opts.width+'px',height:(self.opts.height!='auto'?self.opts.height+'px':'auto')}).mouseenter(function(){var timer=$(this).data('timer');clearTimeout(timer)}).mouseleave(function(){var $self=$(this);$self.data('timer',setTimeout(function(){$self.hide()},self.opts.timeToDisappear))}).appendTo('body')},adjust:function(){var view={width:$(window).width()},element={width:this.$element.width(),height:this.$element.height(),offset:this.$element.offset()},top=element.offset.top+element.height+10,left=element.offset.left+(element.width/2)-(this.$panel.width()/2),offsetRight=view.width-(element.offset.left+(element.width/2)+(this.$panel.width()/2));if(left<0){$('.ui-cp-help-pointer-up',this.$panel).css('margin-left',function(){return(left-7)-(element.width/2)+'px'});left=10}else if(offsetRight<0){$('.ui-cp-help-pointer-up',this.$panel).css('margin-left',Math.abs(offsetRight)+'px');left+=offsetRight-10};this.$panel.css({top:(top+this.opts.offsetTop)+'px',left:(left+this.opts.offsetLeft)+'px'}).show()},reset:function(){if(this.$panel!==null){this.$panel.remove();this.$panel=null}}}