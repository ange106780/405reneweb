var File={};$.fn.fileTree=function(options,directory,content){if(typeof options=='string')return this.data('fileTree')[options](directory,content);var opts=$.extend({root:'/',script:'',folderEvent:'click',expandSpeed:500,collapseSpeed:500,expandEasing:null,collapseEasing:null,multiFolder:true,loadMessage:'Loading...',onFileClick:function(){},onDirExpand:function(){},onDirCollapse:function(){},onShowTree:function(){},additionalParameters:{}},options);return this.each(function(){$(this).data('fileTree',new File.Tree(this,opts))})};File.Tree=function(element,opts){this.$element=$(element);this.$opts=opts;this._init()};File.Tree.prototype={_init:function(){var self=this;self.showTree(self.$element,escape(self.$opts.root),null)},showTree:function(container,dir,content){var self=this;$(container).removeClass('collapsed').addClass('wait');$(".file-tree.start").remove();$(container).find('.start').html('');$(container).find('.folder-image').removeClass('collapsed').addClass('expanded');if(!content){$.get(self.$opts.script,$.extend(self.$opts.additionalParameters,{dir:dir}),function(data){$(container).removeClass('wait').addClass('expanded').append(data);if(self.$opts.root==dir){$(container).find('ul:hidden').show()}else $(container).find('ul:hidden').slideDown({duration:self.$opts.expandSpeed,easing:self.$opts.expandEasing});self.$opts.onShowTree.call(self,container);self.bindTree(container)})}else{$(container).removeClass('wait').addClass('expanded').append(content);if(self.$opts.root==dir){$(container).find('ul:hidden').show()}else $(container).find('ul:hidden').slideDown({duration:self.$opts.expandSpeed,easing:self.$opts.expandEasing});self.$opts.onShowTree.call(self,container);self.bindTree(container)}},bindTree:function(container){var self=this;$(container).find('li a').on(self.$opts.folderEvent,function(){if($(this).parent().hasClass('directory')){if($(this).parent().hasClass('collapsed')){self.expandDir(this);self.$opts.onDirExpand.call(self,$(this).attr('rel'))}else self.collapseDir(this)}else self.$opts.onFileClick.call(self,$(this).attr('rel'));return false});$(container).find('li .folder-image').on('click',function(){if($(this).parent().hasClass('collapsed')){self.expandDir($(this).next('a'))}else self.collapseDir($(this).next('a'));return false});if(self.$opts.folderEvent.toLowerCase!='click')$(container).find('li a').on('click',function(e){e.preventDefault()})},expandDir:function(dirLink,content){var self=this;if(!self.$opts.multiFolder){var $parentUL=$(dirLink).parent().parent();$parentUL.find('ul').slideUp({duration:self.$opts.collapseSpeed,easing:self.$opts.collapseEasing});$parentUL.find('li.directory').removeClass('expanded').addClass('collapsed');$parentUL.find('li.directory .folder-image').removeClass('expanded').addClass('collapsed')};var $li=$(dirLink).parent();$li.find('ul').remove();self.showTree($li,$(dirLink).attr('rel'),content)},collapseDir:function(dirLink){var self=this,$li=$(dirLink).parent();$li.find('ul').slideUp({duration:self.$opts.collapseSpeed,easing:self.$opts.collapseEasing});$li.removeClass('expanded').addClass('collapsed');$li.find('.folder-image').removeClass('expanded').addClass('collapsed')},reloadTree:function(){var self=this;self.$element.empty();self.showTree(self.$element,escape(self.$opts.root))},loadDir:function(directory,content){var self=this;if(!directory||directory=='/'){self.reloadTree()}else{var $dirLink=self.$element.find('a').filter(function(index){return $(this).attr('rel')==directory||$(this).attr('rel')+'/..'==directory});if(directory.match(/\/\.\./)){self.collapseDir($dirLink)}else self.expandDir($dirLink,content)}},reloadDir:function(directory){var self=this;if(!directory||directory=='/'){self.reloadTree()}else{var $dirLink=self.$element.find('a').filter(function(index){return $(this).attr('rel')==directory});self.expandDir($dirLink)}},loadFromInput:function(directory){var self=this,dirArray=new Array();dirArray=directory.replace(/\/+$/,'').split('/');var helper=new Array();for(var pos=1;pos<dirArray.length;pos++)helper[helper.length]=pos;helper.forEach(function(pos){var nextDir=dirArray.slice(0,pos+1).join('/');setTimeout(function(){self.loadDir(nextDir,null)},pos*500)})}}