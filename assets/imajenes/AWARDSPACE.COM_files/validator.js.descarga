$(function(){$('.ui-cp-validate').validatePassword()});$.fn.validatePassword=function(){return this.each(function(){$(this).data('validate.password',new Validate.Password(this))})};var Validate=Validate||{};Validate.Password=function(element){this.$element=$(element);this._init()};Validate.Password.prototype={_init:function(){var self=this;$('span.password-help',self.$element).help();$('input',self.$element).on('input',function(){var password=$(this).val(),value=self.validate(password);$('.ui-cp-validator-message',self.$element).each(function(){$(this).css('display','none')});$('.ui-cp-validator-bar',self.$element).css('background-color','red');switch(value){case'PASSWORD_TOO_SHORT':$('.ui-cp-validator-message.short',self.$element).css('display','block');break;case'PASSWORD_TOO_LONG':$('.ui-cp-validator-message.long',self.$element).css('display','block');break;case'PASSWORD_CONTAINS_NO_DIGIT':$('.ui-cp-validator-message.digit',self.$element).css('display','block');break;case'PASSWORD_CONTAINS_NO_CHAR':$('.ui-cp-validator-message.char',self.$element).css('display','block');break;case'INVALID_PASSWORD':$('.ui-cp-validator-message.invalid',self.$element).css('display','block');break;case'WEAK_PASSWORD':$('.ui-cp-validator-message.weak',self.$element).css('display','block');$('.ui-cp-validator-bar',self.$element).css('background-color','orange');break;case'MEDIUM_PASSWORD':$('.ui-cp-validator-message.medium',self.$element).css('display','block');$('.ui-cp-validator-bar',self.$element).css('background-color','yellow');break;case'STRONG_PASSWORD':$('.ui-cp-validator-message.strong',self.$element).css('display','block');$('.ui-cp-validator-bar',self.$element).css('background-color','green');break;case'NO_PASSWORD':default:$('.ui-cp-validator-message.default',self.$element).css('display','block');$('.ui-cp-validator-bar',self.$element).css('background-color','#c1c1c1');break}})},validate:function(password){if(password.length<1)return'NO_PASSWORD';var strongRegex=/^(?=.{10,})(?=.*[A-Z])(?=.*[a-z])(?=.*[0-9])(?=.*[_!@#%&\/(){}[\]=?+*^~\-.:,;]).*$/g,mediumRegex=/^(?=.{9,})(((?=.*[A-Z])(?=.*[a-z]))|((?=.*[A-Z])(?=.*[0-9]))|((?=.*[a-z])(?=.*[0-9]))).*$/g,validRegex=/^[A-Za-z0-9_!@#%&\/(){}[\]=?+*^~\-.:,;]{8,32}$/,validCharacters=/^[A-Za-z0-9_!@#%&\/(){}[\]=?+*^~\-.:,;]*$/;if(!password.match(validCharacters))return'INVALID_PASSWORD';if(password.length<8)return'PASSWORD_TOO_SHORT';if(password.length>32)return'PASSWORD_TOO_LONG';if(!password.match(/\d/))return'PASSWORD_CONTAINS_NO_DIGIT';if(!password.match(/\w/))return'PASSWORD_CONTAINS_NO_CHAR';if(password.match(strongRegex))return'STRONG_PASSWORD';if(password.match(mediumRegex))return'MEDIUM_PASSWORD';if(password.match(validRegex))return'WEAK_PASSWORD';return'INVALID_PASSWORD'}}