$.fn.slideSelector=function(options){if(typeof options=='string')return this.data('slideSelector')[options]();var opts=$.extend({minValue:0,startValue:14,maxValue:24,range:'min',slider:null,showBars:true,sliderInfo:null,onAdjust:function(){}},options);this.each(function(){$(this).data('slideSelector',new slideSelector(this,opts))});return this};var slideSelector=function(element,opts){this.$element=$(element);this.$opts=opts;this._init()};slideSelector.prototype={_init:function(){var self=this;self.$barsContainer=null;self.$bars=null;self.$infoPanels=null;if(!self.$opts.slider)throw new Error('No slider element provided!');if(self.$opts.showBars){self.$barsContainer=self._createBars();self.$bars=$('li',self.$barsContainer);self.$element.append(self.$barsContainer)};if(self.$opts.sliderInfo!==null)self.$infoPanels=$('.ui-cp-slider-info',self.$opts.sliderInfo);self.$opts.slider.slider({range:self.$opts.range,min:self.$opts.minValue,max:self.$opts.maxValue,value:self.$opts.startValue,animate:true,create:function(e,ui){self._adjust(self.$opts.startValue,self.$bars,self.$infoPanels)},slide:function(e,ui){self._adjust(ui.value,self.$bars,self.$infoPanels)}})},_createBars:function(){var self=this,$ul=$('<ul class="ui-cp-slider-bars"></ul>');for(var i=0;i<=self.$opts.maxValue;i++)$ul.append('<li class="ui-corner-all"></li>');var height=self.$opts.maxValue/4;$('li',$ul).height(function(i,h){return++height});return $ul},_adjust:function(value,bars,infoPanels){var self=this;if(bars!==null){for(var i=0;i<=value;i++)$(bars[i]).addClass('ui-widget-header');for(var i=(bars.length-1);i>value;i--)$(bars[i]).removeClass('ui-widget-header')};if(infoPanels!==null){$(infoPanels).each(function(index){$(this).hide()});$(infoPanels[value]).show()};self.$opts.onAdjust.call(self,infoPanels[value])}}